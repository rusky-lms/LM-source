{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "checkJs": true,
    "allowJs": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@services/*": ["src/services/*"],
      "@adapters/*": ["src/adapters/*"],
      "@components/*": ["src/components/*"]
    },
    "lib": ["ES2022", "DOM"],
    "types": []
  },
  "include": ["src/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
